# DataInsight AI - Frontend Environment Template
# Duplicate this file to '.env' and fill in your production values.

# 1. API connection to FastAPI backend (localhost or deployed server)
VITE_API_URL=http://localhost:8000/api

# 2. Supabase credentials for client-side Auth
VITE_SUPABASE_URL=https://[PROJECT-REFERENCE-ID].supabase.co
VITE_SUPABASE_ANON_KEY=[SUPABASE-ANON-PUBLIC-KEY]
