# DataInsight AI - Backend Environment Template
# Duplicate this file to '.env' and fill in your production values.

# 1. Relational Database Migration (PostgreSQL / Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# 2. File Storage and Authentication (Supabase Cloud Storage & Auth)
SUPABASE_URL=https://[PROJECT-REFERENCE-ID].supabase.co
SUPABASE_ANON_KEY=[SUPABASE-ANON-KEY]
SUPABASE_SERVICE_ROLE_KEY=[SUPABASE-SERVICE-ROLE-KEY]
SUPABASE_BUCKET=datainsight-csv

# 3. AI Insights and Chat Assistant
OPENAI_API_KEY=[OPENAI-API-KEY]
# Set a model name that matches your OpenAI deployment (default: gpt-4o-mini)
#LLM_MODEL=gpt-4o-mini
