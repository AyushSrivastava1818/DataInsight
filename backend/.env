# DataInsight AI - Backend Environment (Local Development)
# This file configures the app to run completely locally without cloud services.
# Change nothing unless you're adding Supabase or OpenAI integration.

# Database: Local SQLite (created automatically in backend/datainsight.db)
DATABASE_URL=sqlite:///./datainsight.db

# Storage: Local filesystem (created automatically in backend/storage/)
USE_CLOUD_STORAGE=False

# AI: Leave blank to use local fallback mode (no API key needed)
OPENAI_API_KEY=

# Max file upload size: 100 MB
MAX_CONTENT_LENGTH=104857600
